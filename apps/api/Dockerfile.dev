# Pin the Go version to match go.mod (avoids surprise toolchain re-resolution on `latest`)
FROM golang:1.26

WORKDIR /app

# Copy manifests first so dependency download is cached as its own layer and
# only re-runs when go.mod / go.sum change (not on every source edit).
COPY go.mod go.sum ./

# Use `go mod download` (not `go mod tidy`): deterministic, verifies against
# go.sum, and doesn't mutate the manifests inside the image.
RUN go mod download

RUN go install github.com/air-verse/air@latest

COPY . .

# Set the entrypoint to the script
ENTRYPOINT ["air"]
